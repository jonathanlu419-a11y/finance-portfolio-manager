# Copy to server/.env for local dev (server/.env is git-ignored).

# Postgres connection string — Neon pooled variant recommended
# (Project → Connection Details → check "Pooled connection"). SSL is required;
# the pool handles it automatically.
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Server port (Render injects PORT automatically in prod — don't set it there)
PORT=3001

# Session cookie Secure flag. false for local http dev; MUST be true in production.
COOKIE_SECURE=false

# Set to "production" on the deployed service. Leave unset locally.
# NODE_ENV=production

# Comma-separated allowed origins for CORS in dev (the Vite dev server).
# Unused in the combined production deploy (same origin) — leave unset there.
CORS_ORIGIN=http://localhost:5173
