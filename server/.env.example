# Neon Postgres pooled connection string (Project → Connection Details → Pooled).
# Neon requires SSL; the pool sets ssl.rejectUnauthorized=false automatically.
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Server port (Render sets PORT automatically in prod)
PORT=3001

# In production the session cookie must be Secure; in local http dev leave this false.
COOKIE_SECURE=false

# Comma-separated allowed origins for CORS in dev (client Vite dev server).
# In the combined prod deploy the app is same-origin, so this is unused.
CORS_ORIGIN=http://localhost:5173
